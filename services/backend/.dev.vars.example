DATABASE_URL=postgresql://username:password@host:5432/database
BETTER_AUTH_SECRET=replace-with-a-random-32-byte-secret
BETTER_AUTH_URL=http://localhost:8787
FRONTEND_ORIGIN=http://localhost:5173
INGESTION_ADMIN_SECRET=replace-with-a-local-admin-secret
ENABLE_DEFAULT_ADMIN_SEED=false
# DEFAULT_ADMIN_EMAIL=admin@example.com
# DEFAULT_ADMIN_PASSWORD=replace-with-dev-password
# DEFAULT_ADMIN_NAME=Admin User

CLICKHOUSE_URL=https://your-instance.clickhouse.cloud:8443
CLICKHOUSE_API_KEY=replace-with-api-key
CLICKHOUSE_API_SECRET=replace-with-api-secret
CCXT_EXCHANGE=binance
CCXT_DELAY_MS=1500
CCXT_BATCH_COOLDOWN_MS=120000
CCXT_MAX_RETRIES=3

# Optional fallback for direct ClickHouse user/password auth instead of API credentials.
# CLICKHOUSE_USERNAME=default
# CLICKHOUSE_PASSWORD=replace-with-password